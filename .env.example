APP_NAME="Alitas Vieja POS"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost
APP_TIMEZONE=America/La_Paz
APP_LOCALE=es

# ─── Base de datos ────────────────────────────────────────────
DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=alitasvega_pos
DB_USERNAME=alitasvega_user
DB_PASSWORD=

# ─── Sesiones ─────────────────────────────────────────────────
SESSION_DRIVER=database
SESSION_LIFETIME=240      # 4 horas — turno típico de trabajo
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

# ─── Cache ────────────────────────────────────────────────────
CACHE_STORE=database

# ─── Colas ────────────────────────────────────────────────────
QUEUE_CONNECTION=database

# ─── Mail (para notificaciones futuras) ───────────────────────
MAIL_MAILER=log
MAIL_FROM_ADDRESS="pos@alitasvieja.com"
MAIL_FROM_NAME="${APP_NAME}"

# ─── Filesystem ───────────────────────────────────────────────
FILESYSTEM_DISK=local
# En producción cambiar a: storage/app/public con symlink
